---
interface Props {
    title?: string;
    description?: string;
}

import Footer from "../components/Footer.astro";
import Head from "../components/Head.astro";
import LocalNotifications from "@/LocalNotifications.vue";
import TitleBar from "../components/navigation/TitleBar.astro";

import "../styles/global.css";
import "@origami-systems/ui/style.css";

const {
    title = "The House App",
    description = "The House App is a cutting-edge tool designed to enrich the educational journey for students and teachers alike. It offers insights to track house-related activities and achievements, fostering engagement within the school community.",
} = Astro.props;
---

<html lang="en" class="light">
    <head>
        <Head title={title} description={description} />

        <slot name="head" />
    </head>
    <body>
        <header id="title-bar-layout-header">
            <TitleBar />
        </header>
        <main id="title-bar-layout">
            <slot />
        </main>
        <Footer />
        <LocalNotifications client:only="vue" />
    </body>
</html>

<style is:global>
    #title-bar-layout {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        padding: 0 10px 10px 10px;
    }

    #title-bar-layout-header {
        margin-bottom: 10px;
    }
</style>
